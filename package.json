{
  "name": "@empty-complete/medusa-product-attributes",
  "version": "0.9.1",
  "description": "Custom attributes module for Medusa v2 with support for text, number, file types and units of measurement",
  "author": "empty-complete",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/empty-complete/medusa-product-attributes"
  },
  "keywords": [
    "medusa",
    "medusajs-v2",
    "medusa-module",
    "custom-attributes",
    "product-attributes",
    "ecommerce",
    "typescript",
    "product"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./models/*": "./dist/models/*.js",
    "./service": "./dist/service.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@medusajs/framework": "^2.13.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
