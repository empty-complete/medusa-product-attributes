{
  "name": "@empty-complete-org/medusa-product-attributes",
  "version": "0.14.0",
  "description": "Custom attributes module for Medusa v2 with support for text, number, file types and units of measurement",
  "author": "empty-complete",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empty-complete/medusa-product-attributes.git"
  },
  "keywords": [
    "medusa",
    "medusa-v2",
    "medusa-plugin",
    "medusa-plugin-integration",
    "custom-attributes",
    "product-attributes",
    "ecommerce",
    "typescript"
  ],
  "files": [
    ".medusa/server",
    "!.medusa/server/**/__tests__"
  ],
  "main": ".medusa/server/src/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "version:inc": "node -e \"const p=require('./package.json'),v=p.version.split('.').map(Number),n=process.argv[2]||'patch';if(n==='major'){v[0]++;v[1]=0;v[2]=0}else if(n==='minor'){v[1]++;v[2]=0}else{v[2]++};p.version=v.join('.');require('fs').writeFileSync('package.json',JSON.stringify(p,null,2))\"",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.13.0",
    "@medusajs/cli": "^2.13.0",
    "@medusajs/framework": "^2.13.0",
    "@medusajs/js-sdk": "^2.13.0",
    "@medusajs/medusa": "^2.13.0",
    "@medusajs/ui": "^4.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@medusajs/admin-sdk": "^2.13.1",
    "@medusajs/cli": "^2.13.1",
    "@medusajs/framework": "^2.13.1",
    "@medusajs/js-sdk": "^2.13.1",
    "@medusajs/medusa": "^2.13.1",
    "@medusajs/ui": "^4.0.27",
    "@mikro-orm/core": "6.4.16",
    "@mikro-orm/migrations": "6.4.16",
    "@tanstack/react-query": "^5.64.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "react": "^19.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "transliteration": "^2.6.1"
  }
}
